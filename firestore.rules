rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============ HELPER FUNCTIONS ============

    function isAuthenticated() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasAnyRole(roles) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userRole() in roles;
    }

    function isAdmin() {
      return hasAnyRole(['ADMIN', 'OPS']);
    }

    // 내부 직원 전체 (CUSTOMER, SUPPLIER, 3PL 제외)
    function isStaff() {
      return hasAnyRole(['ADMIN', 'OPS', 'SALES', 'PURCHASE', 'ACCOUNTING', 'WAREHOUSE']);
    }

    // 본인 문서인지 확인
    function isOwnDocument(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // orderSheet가 게스트(비회원) 발주인지 확인 — 토큰 기반 발주 지원용
    function isGuestOrderSheet(orderSheetId) {
      return exists(/databases/$(database)/documents/orderSheets/$(orderSheetId)) &&
        get(/databases/$(database)/documents/orderSheets/$(orderSheetId)).data.isGuest == true;
    }

    // ============ USERS ============
    match /users/{userId} {
      // 읽기: 본인 문서 또는 내부 직원만
      // (이전엔 모든 인증 사용자가 모든 사용자 정보 read 가능 → CUSTOMER/SUPPLIER 정보 노출 위험)
      allow read: if isOwnDocument(userId) || isStaff();
      // 생성: 본인 문서만 + Firebase UID 일치
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // 수정: 본인 또는 관리자(ADMIN/OPS)
      allow update: if isOwnDocument(userId) || isAdmin();
      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ============ PRODUCTS (상품 마스터) ============
    match /products/{productId} {
      // 읽기: 공개 (공개 카탈로그용)
      allow read: if true;
      // 생성/수정: 내부 직원(상품·구매·영업) — CUSTOMER 차단
      allow create, update: if hasAnyRole(['ADMIN', 'OPS', 'SALES', 'PURCHASE']);
      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ============ ORDER SHEETS (주문장 — 토큰 기반 게스트 허용) ============
    match /orderSheets/{orderSheetId} {
      // 읽기: 공개 (토큰 기반 접근을 위해 필요)
      allow read: if true;
      // 생성: 인증된 사용자이거나, 비회원 발주(isGuest=true)
      allow create: if isAuthenticated() || request.resource.data.isGuest == true;
      // 수정: 인증된 사용자이거나, 기존 게스트 발주(같은 토큰으로 채우는 경우)
      allow update: if isAuthenticated() || resource.data.isGuest == true;
      // 삭제: 내부 직원
      allow delete: if isStaff();
    }

    match /orderSheetItems/{itemId} {
      // 읽기: 공개 (토큰 기반 접근)
      allow read: if true;
      // 생성/수정: 인증된 사용자이거나, 부모 orderSheet가 게스트 발주인 경우만
      allow create: if isAuthenticated() ||
        isGuestOrderSheet(request.resource.data.orderSheetId);
      allow update: if isAuthenticated() ||
        isGuestOrderSheet(resource.data.orderSheetId);
      // 삭제: 내부 직원
      allow delete: if isStaff();
    }

    // ============ SALES ORDERS (확정주문) ============
    match /salesOrders/{salesOrderId} {
      // 읽기: 인증된 사용자 (고객은 자기 것만 보도록 클라이언트 필터)
      allow read: if isAuthenticated();
      // 생성/수정: 영업·창고·관리자
      allow create, update: if hasAnyRole(['ADMIN', 'OPS', 'SALES', 'WAREHOUSE']);
      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    match /salesOrderItems/{itemId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasAnyRole(['ADMIN', 'OPS', 'SALES', 'WAREHOUSE']);
    }

    // ============ PURCHASE ORDERS (매입발주) ============
    match /purchaseOrders/{purchaseOrderId} {
      // 읽기: 구매·창고·관리자 (CUSTOMER 차단)
      allow read: if hasAnyRole(['ADMIN', 'OPS', 'PURCHASE', 'WAREHOUSE']);
      // 생성/수정: 구매·관리자
      allow create, update: if hasAnyRole(['ADMIN', 'OPS', 'PURCHASE']);
      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    match /purchaseOrderItems/{itemId} {
      allow read: if hasAnyRole(['ADMIN', 'OPS', 'PURCHASE', 'WAREHOUSE']);
      allow create, update, delete: if hasAnyRole(['ADMIN', 'OPS', 'PURCHASE']);
    }

    // ============ SHIPMENTS (배송) ============
    match /shipments/{shipmentId} {
      // 읽기: 인증된 사용자 (3PL이 자기 배송 조회)
      allow read: if isAuthenticated();
      // 생성/수정: 창고·영업·3PL·관리자
      allow create, update: if hasAnyRole(['ADMIN', 'OPS', 'SALES', 'WAREHOUSE', '3PL']);
      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ============ VEHICLE TYPES (차량 마스터) ============
    match /vehicleTypes/{vehicleTypeId} {
      // 읽기: 공개 (DispatchView 등 토큰 기반 공개 페이지에서 사용)
      allow read: if true;
      // 생성/수정/삭제: 관리자만 (마스터 데이터)
      allow create, update, delete: if isAdmin();
    }

    // ============ CARRIER DRIVERS (배차기사) ============
    match /carrierDrivers/{driverId} {
      allow read: if isAuthenticated();
      // 3PL이 자기 기사 등록, 관리자/배차담당이 등록
      allow create, update: if hasAnyRole(['ADMIN', 'OPS', '3PL', 'WAREHOUSE']);
      allow delete: if isAdmin();
    }

    // ============ SYSTEM SETTINGS (API 키 등 민감 정보 포함) ============
    match /system/{document=**} {
      // 읽기: 인증된 직원만 (공개 → 인증으로 강화)
      allow read: if isStaff();
      // 생성/수정/삭제: 관리자만
      allow create, update, delete: if isAdmin();
    }

    // LLM 설정 — 인증 사용자 read 허용 (고객 대시보드 AI 해설이 활성 제공자/모델을 읽음).
    // 쓰기는 ADMIN만. ⚠️ 키가 로그인 사용자에게 읽힐 수 있음(B2B 통제계정 전제) —
    // 강화 필요 시 Worker secret으로 이관.
    match /system/llm-settings {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============ DOCUMENTS (레거시 문서 컬렉션 — fileAttachments 권장) ============
    match /documents/{documentId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ============ INVITE TOKENS (고객사 초대 토큰 — users.inviteToken deprecate, 이 컬렉션으로 이관) ============
    match /inviteTokens/{tokenId} {
      // 읽기: 공개 (토큰으로 접근)
      allow read: if true;
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }
    // ============ PRICE LISTS (단가표 — 토큰 기반 게스트 read 허용) ============
    match /priceLists/{document=**} {
      // 읽기: 공개 (토큰 기반)
      allow read: if true;
      // 생성: 영업·관리자
      allow create: if hasAnyRole(['ADMIN', 'OPS', 'SALES']);
      // 수정: 영업·관리자 또는 게스트가 reachCount/conversionCount만 증가
      allow update: if hasAnyRole(['ADMIN', 'OPS', 'SALES']) ||
                    (request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['reachCount', 'conversionCount']));
      allow delete: if isAdmin();
    }

    // ============ PRICE HISTORY (가격 변동 기록) ============
    match /priceHistory/{historyId} {
      allow read: if isStaff();
      // 생성: 가격 변동 시 자동 기록 — 직원만
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // ============ INVENTORY (재고 원장) ============
    match /inventory/{eventId} {
      // 읽기: 내부 직원 전체
      allow read: if isStaff();
      // 생성: 창고·관리자만
      allow create: if hasAnyRole(['ADMIN', 'OPS', 'WAREHOUSE']);
      // 수정/삭제: 관리자만 (재고는 append-only 원칙)
      allow update, delete: if isAdmin();
    }

    // ============ SETTLEMENTS (정산 원장) ============
    match /settlements/{settlementId} {
      // 읽기: 내부 직원 전체 + 해당 고객사 본인
      allow read: if isStaff() ||
        (isAuthenticated() && resource.data.customerOrgId == request.auth.uid);
      // 생성: 출고 시 자동 생성 — 직원만
      allow create: if isStaff();
      // 수정(수금 처리): 정산·관리자만
      allow update: if hasAnyRole(['ADMIN', 'OPS', 'ACCOUNTING']);
      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ============ NOTIFICATIONS (알림) ============
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      // 생성: 시스템 자동 — 인증된 사용자 (서비스에서 호출)
      allow create: if isAuthenticated();
      // 수정: 본인 알림 읽음 처리 — 인증 사용자
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ============ FILE ATTACHMENTS (파일 첨부) ============
    match /fileAttachments/{fileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // 삭제: 업로드 본인 또는 관리자
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.uploadedBy == request.auth.uid);
      allow update: if isAdmin();
    }


    // ============ DOC CATEGORIES (문서 카테고리) ============
    match /docCategories/{categoryId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }
    // ============ MARKET PRICES (외부 시장가격 데이터) ============
    match /marketPrices/{id} {
      // 정부 경매가(비민감) — 고객 대시보드 시세 인사이트가 읽으므로 인증 사용자 read 허용
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============ MARKET NEWS (시장 뉴스) ============
    match /marketNews/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ============ ORDER TEMPLATES (정기/자동 발주 템플릿 — 영업/운영자) ============
    match /orderTemplates/{templateId} {
      allow read, create, update: if isStaff();
      allow delete: if isStaff();
    }

    // ============ SUPPLIER APPLICATIONS (공급사 입점 신청 — 공개 create, 구매/운영자 심사) ============
    match /supplierApplications/{appId} {
      allow create: if true;
      allow read, update: if hasAnyRole(['ADMIN', 'OPS', 'PURCHASE']);
      allow delete: if isAdmin();
    }

    // ============ ONBOARDING INVITES (공급사 온보딩 토큰 — 토큰 소지자 read, 온보딩 중 본인 update) ============
    match /onboardingInvites/{token} {
      allow read: if true;                                   // 토큰으로 접근 (링크 소지자)
      allow create: if hasAnyRole(['ADMIN', 'OPS', 'PURCHASE']);
      allow update: if isAuthenticated();                    // 온보딩 중 공급사 본인이 used 표시
      allow delete: if isAdmin();
    }

    // ============ LEADS (비회원 거래문의 인입 — 공개 create, 영업/운영자 read) ============
    match /leads/{leadId} {
      // 생성: 비회원 포함 누구나 (공개 카탈로그 거래문의 폼)
      allow create: if true;
      // 조회/상태변경: 영업·운영자만
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }
  }
}
