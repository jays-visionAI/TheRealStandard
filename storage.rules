rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 인증된 유저만 업로드 가능
    match /files/{relatedType}/{relatedId}/{fileType}/{fileName} {
      // 읽기: 인증된 유저
      allow read: if request.auth != null;

      // 쓰기: 인증된 유저 + 파일 크기 제한 (20MB)
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('application/pdf')
            || request.resource.contentType.matches('application/octet-stream'));

      // 삭제
      allow delete: if request.auth != null;
    }

    // 상품 미디어 (MediaUploader + 시드 스크립트)
    match /product-media/{productId}/{fileName} {
      // 읽기: 모든 인증된 유저 (공개 카탈로그 포함)
      allow read: if request.auth != null;
      // 쓰기: 인증된 유저 + 이미지만 허용 + 10MB 제한
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      // 삭제: 인증된 유저
      allow delete: if request.auth != null;
    }
  }
}
